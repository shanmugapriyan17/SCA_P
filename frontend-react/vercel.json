{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://smart-career-advisor-api.onrender.com/api/:path*"
        },
        {
            "source": "/health",
            "destination": "https://smart-career-advisor-api.onrender.com/health"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://smart-career-advisor-api.onrender.com/uploads/:path*"
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}